# Copy to .env and fill. Never commit .env.

# Agent pipeline. Leave empty to run in mock-agent mode (no API cost).
ANTHROPIC_API_KEY=

# Session token signing. Generate: python -c "import secrets;print(secrets.token_hex(32))"
APP_SECRET_KEY=

# Owner login. Set via: python -m app.cli set-password
APP_PASSWORD_HASH=

# Alerts (Milestone 7). Create bot via @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional overrides
# DB_PATH=../data/copilot.db
# PAPER_STARTING_CASH=1000000
